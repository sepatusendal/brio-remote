<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.wiramodepohon.brio-server</string>

    <key>ProgramArguments</key>
    <array>
        <string>__NODE_PATH__</string>
        <string>__SERVER_INDEX_PATH__</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__SERVER_DIR__</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>BRIO_TOKEN</key>
        <string>__BRIO_TOKEN__</string>
        <key>PORT</key>
        <string>3000</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/brio-server.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/brio-server.error.log</string>
</dict>
</plist>
